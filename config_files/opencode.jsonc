{
    "$schema": "https://kilo.ai/config.json",
    "enabled_providers": ["llm-proxy-4-code"],
    "disabled_providers": ["openai", "anthropic", "gemini", "openrouter", "openrama"],
    "provider": {
      "llm-proxy-4-code": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "llm-proxy-4-code",
        "options": {
          "baseURL": "<openai-compatible-api-url>"
        },
        "models": {
          "openai/omni-moderation-latest": {
            "name": "openai/omni-moderation-latest"
          },
          "openai/gpt-5.1-codex": {
            "name": "openai/gpt-5.1-codex"
          },
          "openai/gpt-5.1-codex-max": {
            "name": "openai/gpt-5.1-codex-max"
          },
          "openai/gpt-5.2-codex": {
            "name": "openai/gpt-5.2-codex"
          },
          "openai/gpt-5.2": {
            "name": "openai/gpt-5.2"
          },
          "openai/gpt-5": {
            "name": "openai/gpt-5"
          },
          "openai/gpt-5-mini": {
            "name": "openai/gpt-5-mini"
          },
          "gemma3-12b": {
            "name": "gemma3-12b"
          },
          "nomic-embed-text-latest": {
            "name": "nomic-embed-text-latest"
          },
          "gpt-oss-20b": {
            "name": "gpt-oss-20b"
          },
          "qwen3-coder-next": {
            "name": "qwen3-coder-next"
          },
          "qwen3.5-35b-instruct": {
            "name": "qwen3.5-35b-instruct"
          },
          "devstral-small-2-24b-instruct": {
            "name": "devstral-small-2-24b-instruct"
          },
          "qwen2.5-coder-7b-instruct": {
            "name": "qwen2.5-coder-7b-instruct"
          },
          "bge-m3": {
            "name": "bge-m3"
          }
        }
      }
    }
  }